---
const { titulo, desc } = Astro.props;
---

<div class="titleSection">
  <h2>{titulo}</h2>
  <div class="titleDesc">
    <slot />
  </div>
</div>

<style>
  .titleSection {
    box-sizing: border-box;
    position: relative;
  }

  h2 {
    position: absolute;
    top: 0;
    left: 0;
    margin: 0;
  }

  .titleDesc {
    padding-top: 40px;
    margin-left: auto;
    max-width: 500px;
    text-align: right;
  }
</style>