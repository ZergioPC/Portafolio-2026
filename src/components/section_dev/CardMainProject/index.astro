---
//const { isOpen } = Astro.props
---
<article {...Astro.props}>
  <div>
    <div class="portada">
      <slot name="portada" />
    </div>
    <div class="content">
      <slot name="content" />
    </div>
  </div>
</article>

<style>
  /* Tarjeta */
  article {
    height: 300px;
    background-color: gray;
    border-radius: 20px;
    transition: 300ms;
    overflow: hidden;
  }

  article > div {
    display: grid;
    grid-template-columns: 1fr 1fr;
    aspect-ratio: 2/1;
    height: 100%;
    width: auto;
  }

  article[card-state="default"] { width: 300px;}
  article[card-state="open"] { width: 600px;}
  article[card-state="close"] { width: 0px;}

  /* Contenido */

  .portada, .content {
    aspect-ratio: 1/1;
    height: 100%;
    width: auto;
  }

  .portada {
    background-color: #fff;
    overflow: hidden;
  }

  .content {
    box-sizing: border-box;
    padding: 15px;
    background-color: aqua;
  }
</style>